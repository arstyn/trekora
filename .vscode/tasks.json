{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Run All (Dev)",
      "dependsOn": [
        "Run Backend",
        "Run Frontend"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build Backend",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/apps/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend-build"
      },
      "problemMatcher": []
    },
    {
      "label": "Build Frontend",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/apps/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend-build"
      },
      "problemMatcher": []
    },
    {
      "label": "Build All",
      "dependsOn": [
        "Build Backend",
        "Build Frontend"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
